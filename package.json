{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "packageManager": "pnpm@11.1.3",
  "scripts": {
    "preinstall": "node scripts/ensure-pnpm.cjs",
    "dev": "pnpm --filter @workspace/personal-site run dev",
    "build": "pnpm run typecheck && pnpm --filter @workspace/personal-site run build",
    "preview": "pnpm --filter @workspace/personal-site run serve",
    "site:build": "pnpm --filter @workspace/personal-site run build",
    "site:preview": "pnpm --filter @workspace/personal-site run serve",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck"
  },
  "private": true,
  "devDependencies": {
    "prettier": "^3.8.3",
    "typescript": "~5.9.3"
  }
}
